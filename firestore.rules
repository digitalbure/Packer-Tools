rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (Secured)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSignedIn() {
      return isAuthenticated();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "jnakasamai@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true
        ))
      );
    }

    function isCollaborator(listId) {
      let listData = get(/databases/$(database)/documents/packingLists/$(listId)).data;
      return isAuthenticated() && (
        (listData.collaboratorIds != null && request.auth.uid in listData.collaboratorIds) ||
        (listData.collaboratorEmails != null && request.auth.token.email in listData.collaboratorEmails)
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function isUnchanged(key) {
      return !(key in request.resource.data) || request.resource.data[key] == resource.data[key];
    }

    // Schema Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'plan']) &&
             data.uid is string &&
             data.email is string &&
             data.plan is string;
    }

    function isValidPlan(data) {
      return data.keys().hasAll(['name', 'price', 'features', 'aiTokenLimit']) &&
             data.name is string && data.name.size() > 0 &&
             data.price is number &&
             data.features is list &&
             data.aiTokenLimit is int;
    }

    function isValidPackingList(data) {
      return data.keys().hasAll(['ownerId', 'name']) &&
             data.ownerId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidItem(data) {
      return data.keys().hasAll(['listId', 'name', 'assetTag']) &&
             data.listId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.assetTag is string;
    }

    function isValidGearItem(data) {
      return data.keys().hasAll(['ownerId', 'name', 'assetTag', 'quantity']) &&
             data.ownerId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.assetTag is string &&
             data.quantity is number && data.quantity >= 1;
    }

    function isValidRack(data) {
      return data.keys().hasAll(['ownerId', 'name', 'totalUnits']) &&
             data.ownerId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.totalUnits is int && data.totalUnits > 0 && data.totalUnits <= 48;
    }

    function isValidRackItem(data) {
      return data.keys().hasAll(['rackId', 'name', 'uPosition', 'uHeight']) &&
             data.rackId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.uPosition is int && data.uPosition > 0 &&
             data.uHeight is int && data.uHeight > 0;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['ownerId', 'name', 'status', 'listIds']) &&
             data.ownerId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.status in ['planning', 'packing', 'moving', 'completed', 'active', 'on-hold'] &&
             data.listIds is list;
    }

    function isValidContainer(data) {
      return data.keys().hasAll(['name', 'type', 'items']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type is string &&
             data.items is list;
    }

    function isValidContact(data) {
      return data.keys().hasAll(['ownerId', 'name', 'type']) &&
             data.ownerId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type is string;
    }

    function isValidSupplier(data) {
      return data.keys().hasAll(['projectId', 'ownerId', 'name']) &&
             data.projectId is string &&
             data.ownerId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidCost(data) {
      return data.keys().hasAll(['projectId', 'ownerId', 'amount', 'status']) &&
             data.projectId is string &&
             data.ownerId is string &&
             data.amount >= 0 &&
             data.status is string && data.status.size() > 0 && data.status.size() < 100;
    }

    function isValidBugReport(data) {
      return data.keys().hasAll(['userId', 'title', 'description', 'status']) &&
             data.userId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.status in ['open', 'in_review', 'resolved', 'fixed'];
    }

    function isValidActivityLog(data) {
      return data.keys().hasAll(['userId', 'userName', 'actionType', 'description', 'timestamp', 'metadata']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 128 &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() < 256 &&
             data.actionType is string && data.actionType.size() > 0 && data.actionType.size() < 64 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1024 &&
             data.timestamp is string &&
             data.metadata is map;
    }

    function isValidBookingCondition(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200;
    }

    function isValidGearBooking(data) {
      return data.keys().hasAll(['gearId', 'ownerId', 'clientName', 'startDate', 'endDate']) &&
             data.gearId is string &&
             data.ownerId is string &&
             data.clientName is string && data.clientName.size() > 0 && data.clientName.size() < 100 &&
             data.startDate is string &&
             data.endDate is string;
    }

    function isValidOrganization(data) {
      return data.keys().hasAll(['name', 'slug']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() < 100;
    }

    function isValidMovingProject(data) {
      return data.keys().hasAll(['ownerId', 'name', 'status']) &&
             data.ownerId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.status in ['planning', 'packing', 'moving', 'completed', 'active', 'on-hold'];
    }

    function isValidTerminal(data) {
      return data.keys().hasAll(['pairingCode', 'status']) &&
             data.pairingCode is string &&
             data.status in ['pending', 'active'];
    }

    function isValidBuildItem(data) {
      return data.keys().hasAll(['projectId', 'ownerId', 'name']) &&
             data.projectId is string &&
             data.ownerId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }


    // ===============================================================
    // Rules Configuration (Secured Paths)
    // ===============================================================

    // 1. User Profiles & Subcollections
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().plan == 'free' && (!('role' in incoming()) || incoming().role == 'user');
      allow update: if isOwner(userId) && (
        isAdmin() || (
          isUnchanged('plan') &&
          isUnchanged('role') &&
          isUnchanged('isSuperAdmin') &&
          isUnchanged('extraSeats') &&
          isUnchanged('manualPaymentPending')
        )
      );
      allow delete: if isAdmin();

      // Nested Gear Library
      match /gearLibrary/{itemId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId) && isValidGearItem(incoming());
        allow update: if isOwner(userId) && isValidGearItem(incoming());
        allow delete: if isOwner(userId);

        match /versions/{versionId} {
          allow read: if isSignedIn();
          allow write: if isOwner(userId);
        }

        match /incidents/{incidentId} {
          allow read: if isSignedIn();
          allow write: if isOwner(userId);
        }
      }

      // Reusable Containers
      match /containers/{containerId} {
        allow read: if isSignedIn();
        allow create, update: if isOwner(userId) && isValidContainer(incoming());
        allow delete: if isOwner(userId);
      }

      // Booking Conditions
      match /bookingConditions/{conditionId} {
        allow read: if isSignedIn();
        allow create, update: if isOwner(userId) && isValidBookingCondition(incoming());
        allow delete: if isOwner(userId);
      }

      // Maintenance Logs
      match /maintenanceLogs/{logId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
    }

    // 2. Collection Group Rules
    match /{path=**}/gearLibrary/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        request.auth.uid == resource.data.ownerId || request.auth.uid == request.resource.data.ownerId
      );
    }

    match /{path=**}/items/{itemId} {
      // Unused collection group locked down
      allow read, write: if false;
    }

    // 3. User Contacts
    match /contacts/{contactId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerId && isValidContact(incoming());
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && request.auth.uid == incoming().ownerId && isValidContact(incoming());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // 4. Packing Lists & Subcollections (Items, Versions)
    match /packingLists/{listId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || isCollaborator(listId) || resource.data.marketplaceEnabled == true || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerId && isValidPackingList(incoming());
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isCollaborator(listId)) && (resource.data.ownerId == incoming().ownerId) && isValidPackingList(incoming());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      match /items/{itemId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/packingLists/$(listId)).data.ownerId == request.auth.uid || isCollaborator(listId) || isAdmin());
        allow write: if isSignedIn() && (get(/databases/$(database)/documents/packingLists/$(listId)).data.ownerId == request.auth.uid || isCollaborator(listId) || isAdmin());
      }

      match /versions/{versionId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/packingLists/$(listId)).data.ownerId == request.auth.uid || isCollaborator(listId) || isAdmin());
        allow write: if isSignedIn() && (get(/databases/$(database)/documents/packingLists/$(listId)).data.ownerId == request.auth.uid || isAdmin());
      }
    }

    // 5. Global Admin Settings
    match /adminSettings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 6. Subscription plans
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 7. Marketplace Categories
    match /marketplaceCategories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 8. Custom Compliance Pages
    match /pages/{pageId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 9. Equipment Racks
    match /racks/{rackId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerId && isValidRack(incoming());
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && request.auth.uid == incoming().ownerId && isValidRack(incoming());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      match /items/{itemId} {
        allow read, write: if isSignedIn() && (get(/databases/$(database)/documents/racks/$(rackId)).data.ownerId == request.auth.uid || isAdmin());
      }
    }

    // 10. AV Build/Sandbox Projects
    match /projects/{projectId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerId && isValidProject(incoming());
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && request.auth.uid == incoming().ownerId && isValidProject(incoming());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // 11. Build Sandbox Items
    match /buildItems/{itemId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerId && isValidBuildItem(incoming());
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && request.auth.uid == incoming().ownerId && isValidBuildItem(incoming());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // 12. Sandbox Item Suppliers
    match /suppliers/{supplierId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerId && isValidSupplier(incoming());
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && request.auth.uid == incoming().ownerId && isValidSupplier(incoming());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // 13. Financial Project Costs
    match /projectCosts/{costId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerId && isValidCost(incoming());
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && request.auth.uid == incoming().ownerId && isValidCost(incoming());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // 14. Household Moving Projects
    match /movingProjects/{projectId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerId && isValidMovingProject(incoming());
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && request.auth.uid == incoming().ownerId && isValidMovingProject(incoming());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // 15. Active User Reminders
    match /reminders/{reminderId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerId;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && request.auth.uid == incoming().ownerId;
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // 16. Help & Documentation Articles
    match /helpArticles/{articleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 17. Interactive Kiosk Terminals
    match /terminals/{terminalId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerUid && isValidTerminal(incoming());
      allow update: if isSignedIn() && resource.data.ownerUid == request.auth.uid && request.auth.uid == incoming().ownerUid && isValidTerminal(incoming());
      allow delete: if isSignedIn() && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // 18. Checked out gear
    match /checkouts/{checkoutId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 19. Terminal / Guest orders
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().userId;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 20. Organization Invites
    match /invitations/{inviteId} {
      allow read: if isSignedIn() && (resource == null || resource.data.email == request.auth.token.email || resource.data.invitedBy == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.email == request.auth.token.email || resource.data.invitedBy == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.invitedBy == request.auth.uid || isAdmin());
    }

    // 21. Master Organizations
    match /organizations/{orgId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || resource.id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerId && isValidOrganization(incoming());
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && request.auth.uid == incoming().ownerId && isValidOrganization(incoming());
      allow delete: if isAdmin();
    }

    // 22. Org Departments
    match /departments/{deptId} {
      allow read: if isSignedIn() && (resource == null || resource.data.orgId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || resource.data.orgId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId);
      allow delete: if isAdmin();
    }

    // 23. Dept Teams
    match /teams/{teamId} {
      allow read: if isSignedIn() && (resource == null || resource.data.orgId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || resource.data.orgId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId);
      allow delete: if isAdmin();
    }

    // 24. Sheet Inventories & Subcollections (Items)
    match /inventories/{inventoryId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || resource.data.orgId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().ownerId;
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.orgId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId || isAdmin());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      match /items/{itemId} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/inventories/$(inventoryId)).data.ownerId == request.auth.uid ||
          get(/databases/$(database)/documents/inventories/$(inventoryId)).data.orgId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId ||
          isAdmin()
        );
      }
    }

    // 25. Community Shared Stories / Case Studies
    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 26. Bug Reports
    match /bugs/{bugId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().userId && isValidBugReport(incoming());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 27. Marketplace Bookings / Rentals
    match /gearBookings/{bookingId} {
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || resource.data.clientEmail == request.auth.token.email || isAdmin());
      allow create: if isSignedIn() && isValidGearBooking(incoming());
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // 28. Platform Audit Activity Logs
    match /activityLogs/{logId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().userId && isValidActivityLog(incoming());
      allow update, delete: if isAdmin();
    }
  }
}
