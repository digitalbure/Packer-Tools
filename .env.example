# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
VITE_PAYPAL_CLIENT_ID="YOUR_PAYPAL_CLIENT_ID"
PAYPAL_SECRET_KEY="YOUR_PAYPAL_SECRET_KEY"

# RESEND_API_KEY: Optional. Secret key for transactional kiosk check-out/check-in emails.
# Sign up at https://resend.com to obtain a free key.
RESEND_API_KEY="YOUR_RESEND_API_KEY"

# GCP_PRICING_API_KEY: Optional. Custom API key for fetching SKUs from the GCP Cloud Billing Catalog API.
# If omitted, Gemini API key is used as fallback, or the simulation gracefully uses real GCP published rates.
GCP_PRICING_API_KEY=""

